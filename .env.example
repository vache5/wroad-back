PORT=4000
NODE_ENV=development

# MongoDB (required). URL-encode special characters in the password.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/wineroad?retryWrites=true&w=majority

# Admin JWT (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Admin login (email must match login form)
ADMIN_EMAIL=admin@wineroad.am

# Prefer bcrypt hash in production (e.g. bcrypt.hashSync("your-password", 10))
# ADMIN_PASSWORD_HASH=$2a$10$...
# For local dev only, you may omit ADMIN_PASSWORD_HASH and set:
ADMIN_PASSWORD=change-me

# Comma-separated browser Origins (https, no trailing slash, no spaces). Never list your API host here.
# Example (local Next + Vercel preview):
# CORS_ORIGINS=http://localhost:3000,https://wineroad-app-d1t6.vercel.app
CORS_ORIGINS=http://localhost:3000,https://wineroad-app-d1t6.vercel.app

# Temporary: allow any browser Origin (reflects request origin; works with credentials). Remove for production.
# CORS_ALLOW_ALL=true

# Public base URL for this API (used to build absolute image URLs in responses).
# Production example (Render):
# BASE_URL=https://your-backend-name.onrender.com
# Development fallback when omitted:
# http://localhost:4000
BASE_URL=http://localhost:4000

# Where `/images/*` should be served from.
# If your images live in the frontend (Next.js `public/images`), set this to your Vercel domain:
# IMAGES_BASE_URL=https://your-frontend.vercel.app
# (Dev fallback: http://localhost:3000)
# If you instead host images on the backend under `/images`, set this to BASE_URL.
# IMAGES_BASE_URL=http://localhost:4000

# Optional public origin used when generating uploaded image URLs.
# PUBLIC_API_BASE_URL=https://api.wineroad.am
